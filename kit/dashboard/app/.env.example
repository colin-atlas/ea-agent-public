# === Required ===

# Absolute path to your OpenClaw agent's workspace directory
# (the directory containing SOUL.md, db/, brain/, etc.)
WORKSPACE_PATH=/home/youruser/.openclaw/workspace

# Session secret — generate with: openssl rand -hex 32
SESSION_SECRET=

# === Optional ===

# Dashboard display name (shown in UI header)
NEXT_PUBLIC_APP_NAME=My Dashboard

# Organization name
NEXT_PUBLIC_ORG_NAME=My Company

# Session cookie name (change if running multiple dashboards)
SESSION_COOKIE_NAME=ea-dashboard-session

# Session duration in days (default: 30)
SESSION_DURATION_DAYS=30

# Link to your knowledge base or docs site (shown in sidebar)
# NEXT_PUBLIC_DOCS_URL=https://your-docs-site.example.com

# If your agent runs in Docker, set this to the docker-compose.yml directory
# DOCKER_COMPOSE_DIR=/home/youruser/clients/my-agent

# Port (default: 3000, override via systemd or CLI)
# PORT=3000
