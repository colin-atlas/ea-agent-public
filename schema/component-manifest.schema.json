{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/colin-atlas/atlas-ea-agent-public/schema/component-manifest.schema.json",
  "title": "Atlas Kit Component Manifest",
  "description": "Schema for every manifest.json under kit/ in atlas-ea-agent-public.",
  "type": "object",
  "required": ["id", "type", "version", "description", "bundles", "requires", "files"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(identity|skills|db|scripts|dashboard)/[a-z0-9][a-z0-9-]*$",
      "description": "Globally unique component ID. Format: '<type>/<slug>'."
    },
    "type": {
      "type": "string",
      "enum": ["identity", "skills", "db", "scripts", "dashboard"]
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver MAJOR.MINOR.PATCH."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "bundles": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "uniqueItems": true
    },
    "requires": {
      "type": "object",
      "additionalProperties": false,
      "required": ["components", "placeholders", "env"],
      "properties": {
        "components": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(identity|skills|db|scripts|dashboard)/[a-z0-9][a-z0-9-]*$"
          },
          "uniqueItems": true
        },
        "placeholders": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          },
          "uniqueItems": true
        },
        "env": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          },
          "uniqueItems": true
        }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["src", "dest"],
        "additionalProperties": false,
        "properties": {
          "src": {
            "type": "string",
            "minLength": 1,
            "description": "Path relative to this component's directory."
          },
          "dest": {
            "type": "string",
            "minLength": 1,
            "description": "Destination path relative to the agent's workspace root."
          },
          "template": {
            "type": "boolean",
            "default": false,
            "description": "If true, run [PLACEHOLDER] substitution on the file during copy."
          }
        }
      }
    },
    "post_install": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
